<mvc:View
    controllerName="zpp4pointinsp.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
>
    <Page
        id="page"
        title="4 Point Inspection Module - Zeel(Textile)"
        showHeader="true"
        showFooter="true"
        busy="{vm>/busy}"
        class="sapUiContentPadding"
    >
        <content>
            <VBox class="sapUiResponsiveMargin">

              <Panel
    headerText="Selection Screen"
    class="customPanel sapUiTinyMarginBottom"
>
    <l:Grid
        defaultSpan="XL4 L4 M6 S12"
        hSpacing="1"
        vSpacing="1"
        width="100%"
    >

        <!-- SECTION 1: Order Details -->
        <VBox class="sectionBox">
            <Title
                text="Order Details"
                level="H5"
                class="sectionTitle"
            />

            <VBox class="fieldBlock">
                <Label text="Production Order" design="Bold" />
                <Input
                    id="prodOrderInput"
                    value="{vm>/selection/productionOrder}"
                    change=".onProductionOrderChange"
                    suggest=".onProductionOrderSuggest"
                    suggestionItemSelected=".onProductionOrderSuggestionSelected"
                    valueHelpRequest=".onProductionOrderValueHelp"
                    showSuggestion="true"
                    showValueHelp="true"
                    filterSuggests="false"
                    startSuggestion="1"
                    suggestionRows="{vm>/productionOrders}"
                    placeholder="Enter or select Production Order"
                    width="100%"
                    class="whiteInputBox"
                >
                    <suggestionColumns>
                        <Column>
                            <Text text="Production Order" />
                        </Column>
                        <Column>
                            <Text text="Sales Order" />
                        </Column>
                        <Column>
                            <Text text="Item" />
                        </Column>
                        <Column>
                            <Text text="Batch" />
                        </Column>
                    </suggestionColumns>

                    <suggestionRows>
                        <ColumnListItem>
                            <cells>
                                <Text text="{vm>Product_Order}" />
                                <Text text="{vm>SalesOrder}" />
                                <Text text="{vm>SalesOrderItem}" />
                                <Text text="{vm>Batch}" />
                            </cells>
                        </ColumnListItem>
                    </suggestionRows>
                </Input>
            </VBox>

            <HBox
                width="100%"
                alignItems="Start"
                justifyContent="SpaceBetween"
                class="fieldBlock"
            >
                <VBox width="49%">
                    <Label text="Sales Order" design="Bold" />
                    <Text
                        text="{vm>/selection/salesOrder}"
                        width="100%"
                        class="readOnlyWhiteBox"
                    >
                        <customData>
                            <core:CustomData
                                key="placeholder"
                                value="Auto fetched Sales Order"
                                writeToDom="true"
                            />
                        </customData>
                    </Text>
                </VBox>

                <VBox width="49%">
                    <Label text="Sales Order Item" design="Bold" />
                    <Text
                        text="{vm>/selection/salesOrderItem}"
                        width="100%"
                        class="readOnlyWhiteBox"
                    >
                        <customData>
                            <core:CustomData
                                key="placeholder"
                                value="Auto fetched Item"
                                writeToDom="true"
                            />
                        </customData>
                    </Text>
                </VBox>
            </HBox>

            <VBox class="fieldBlock">
                <Label text="Product" design="Bold" />
                <Text
                    text="{vm>/selection/product}"
                    width="100%"
                    class="readOnlyWhiteBox"
                >
                    <customData>
                        <core:CustomData
                            key="placeholder"
                            value="Auto fetched Product"
                            writeToDom="true"
                        />
                    </customData>
                </Text>
            </VBox>

            <VBox class="fieldBlock">
                <Label text="Batch" design="Bold" />
                <Text
                    text="{vm>/selection/batch}"
                    width="100%"
                    class="readOnlyWhiteBox"
                >
                    <customData>
                        <core:CustomData
                            key="placeholder"
                            value="Auto fetched Batch"
                            writeToDom="true"
                        />
                    </customData>
                </Text>
            </VBox>

            <HBox
                width="100%"
                alignItems="Start"
                justifyContent="SpaceBetween"
                class="fieldBlock"
            >
                <VBox width="49%">
                    <Label text="Quantity" design="Bold" />
                    <Text
                        text="{vm>/selection/quantity}"
                        width="100%"
                        class="readOnlyWhiteBox"
                    >
                        <customData>
                            <core:CustomData
                                key="placeholder"
                                value="Auto fetched Qty"
                                writeToDom="true"
                            />
                        </customData>
                    </Text>
                </VBox>

                <VBox width="49%">
                    <Label text="UOM" design="Bold" />
                    <Text
                        text="{vm>/selection/uom}"
                        width="100%"
                        class="readOnlyWhiteBox"
                    >
                        <customData>
                            <core:CustomData
                                key="placeholder"
                                value="Auto fetched UOM"
                                writeToDom="true"
                            />
                        </customData>
                    </Text>
                </VBox>
            </HBox>
        </VBox>

        <!-- SECTION 2: Inspection Details -->
        <VBox class="sectionBox">
            <Title
                text="Inspection Details"
                level="H5"
                class="sectionTitle"
            />

            <HBox
                width="100%"
                alignItems="Start"
                justifyContent="SpaceBetween"
                class="fieldBlock"
            >
                <VBox width="49%">
                    <Label text="GRN Quantity" design="Bold" />
                    <Text
                        text="{vm>/selection/grnQuantity}"
                        width="100%"
                        class="readOnlyWhiteBox"
                    >
                        <customData>
                            <core:CustomData
                                key="placeholder"
                                value="Auto fetched GRN Qty"
                                writeToDom="true"
                            />
                        </customData>
                    </Text>
                </VBox>

                <VBox width="49%">
                    <Label text="GRN UOM" design="Bold" />
                    <Text
                        text="{vm>/selection/grnUom}"
                        width="100%"
                        class="readOnlyWhiteBox"
                    >
                        <customData>
                            <core:CustomData
                                key="placeholder"
                                value="Auto fetched GRN UOM"
                                writeToDom="true"
                            />
                        </customData>
                    </Text>
                </VBox>
            </HBox>

            <HBox
                width="100%"
                alignItems="Start"
                justifyContent="SpaceBetween"
                class="fieldBlock"
            >
                <VBox width="49%">
                    <Label text="From Storage Location" design="Bold" />
                    <Text
                        text="{vm>/selection/fromStorageLocation}"
                        width="100%"
                        class="readOnlyWhiteBox"
                    >
                        <customData>
                            <core:CustomData
                                key="placeholder"
                                value="Auto fetched From Store"
                                writeToDom="true"
                            />
                        </customData>
                    </Text>
                </VBox>

                <VBox width="49%">
                    <Label text="To Storage Location" design="Bold" />
                    <Select
                        selectedKey="{vm>/selection/toStorageLocation}"
                        items="{vm>/storageLocations}"
                        width="100%"
                        class="whiteSelectBox"
                    >
                        <core:Item
                            key="{vm>key}"
                            text="{vm>text}"
                        />
                    </Select>
                </VBox>
            </HBox>

            <HBox
                width="100%"
                alignItems="Start"
                justifyContent="SpaceBetween"
                class="fieldBlock"
            >
                <VBox width="49%">
                    <Label text="Shift" design="Bold" />
                    <Select
                        selectedKey="{vm>/selection/shift}"
                        items="{vm>/shifts}"
                        width="100%"
                        class="whiteSelectBox"
                    >
                        <core:Item
                            key="{vm>key}"
                            text="{vm>text}"
                        />
                    </Select>
                </VBox>

                <VBox width="49%">
                    <Label text="Length" design="Bold" />
                    <Input
                        value="{vm>/selection/length}"
                        type="Number"
                        placeholder="Enter Length"
                        width="100%"
                        class="whiteInputBox"
                    />
                </VBox>
            </HBox>

            <HBox
                width="100%"
                alignItems="Start"
                justifyContent="SpaceBetween"
                class="fieldBlock"
            >
                <VBox width="49%">
                    <Label text="Inspected Qty" design="Bold" />
                    <Text
                        text="{vm>/selection/inspectedQuantity}"
                        width="100%"
                        class="readOnlyWhiteBox"
                    >
                        <customData>
                            <core:CustomData
                                key="placeholder"
                                value="Auto calculated Qty"
                                writeToDom="true"
                            />
                        </customData>
                    </Text>
                </VBox>

                <VBox width="49%">
                    <Label text="Inspected UOM" design="Bold" />
                    <Text
                        text="{vm>/selection/inspectedUom}"
                        width="100%"
                        class="readOnlyWhiteBox"
                    >
                        <customData>
                            <core:CustomData
                                key="placeholder"
                                value="Auto fetched UOM"
                                writeToDom="true"
                            />
                        </customData>
                    </Text>
                </VBox>
            </HBox>

            <HBox
                width="100%"
                alignItems="Start"
                justifyContent="SpaceBetween"
                class="fieldBlock"
            >
                <VBox width="32%">
                    <Label text="G.WT" design="Bold" />
                    <Input
                        value="{vm>/selection/grossWeight}"
                        type="Number"
                        placeholder="Enter Gross"
                        liveChange=".onWeightChange"
                        change=".onWeightChange"
                        width="100%"
                        class="whiteInputBox"
                    />
                </VBox>

                <VBox width="32%">
                    <Label text="T.WT" design="Bold" />
                    <Input
                        value="{vm>/selection/tareWeight}"
                        type="Number"
                        placeholder="Enter Tare"
                        liveChange=".onWeightChange"
                        change=".onWeightChange"
                        width="100%"
                        class="whiteInputBox"
                    />
                </VBox>

                <VBox width="32%">
                    <Label text="N.WT" design="Bold" />
                    <Text
                        text="{vm>/selection/netWeight}"
                        width="100%"
                        class="readOnlyWhiteBox"
                    >
                        <customData>
                            <core:CustomData
                                key="placeholder"
                                value="Auto calculated Net"
                                writeToDom="true"
                            />
                        </customData>
                    </Text>
                </VBox>
            </HBox>
        </VBox>

        <!-- SECTION 3: Defect Entry Details -->
        <VBox class="sectionBox">
            <Title
                text="Defect Entry Details"
                level="H5"
                class="sectionTitle"
            />

            <VBox class="fieldBlock">
                <Label text="Process" design="Bold" />
                <Select
                    selectedKey="{vm>/selection/process}"
                    items="{vm>/processes}"
                    change=".onProcessChange"
                    width="100%"
                    class="whiteSelectBox"
                >
                    <core:Item
                        key="{vm>key}"
                        text="{vm>text}"
                    />
                </Select>
            </VBox>

            <VBox class="fieldBlock">
                <Label text="Meter Reading" design="Bold" />
                <Input
                    value="{vm>/selection/meterReading}"
                    placeholder="Enter Meter Reading"
                    type="Number"
                    submit=".onMeterReadingSubmit"
                    width="100%"
                    class="whiteInputBox"
                />
            </VBox>

            <VBox class="fieldBlock">
                <Label text="Operator" design="Bold" />
                <Select
                    selectedKey="{vm>/selection/operator}"
                    items="{vm>/operators}"
                    width="100%"
                    class="whiteSelectBox"
                >
                    <core:Item
                        key="{vm>key}"
                        text="{vm>text}"
                    />
                </Select>
            </VBox>

            <VBox class="fieldBlock">
                <Label text="Machine Name" design="Bold" />
                <Select
                    selectedKey="{vm>/selection/machineName}"
                    items="{vm>/machines}"
                    width="100%"
                    class="whiteSelectBox"
                >
                    <core:Item
                        key="{vm>key}"
                        text="{vm>text}"
                    />
                </Select>
            </VBox>
        </VBox>

    </l:Grid>
</Panel>

              <Panel
    headerText="Defect Quick-Capture (Click button to record)"
    class="customPanel sapUiTinyMarginBottom"
>
    <l:Grid
        defaultSpan="XL3 L3 M4 S12"
        hSpacing="1"
        vSpacing="1"
        width="100%"
        content="{vm>/currentDefects}"
    >
        <Button
            text="{vm>name}"
            press=".onDefectClick"
            width="100%"
            class="defectCaptureButton"
        />
    </l:Grid>
</Panel>
                <Table
                    id="defectsTable"
                    items="{vm>/capturedDefects}"
                    headerText="Captured Defects Log"
                    noDataText="No defects captured yet."
                >
                    <columns>
                        <Column>
                            <Text text="Operator" />
                        </Column>

                        <Column>
                            <Text text="Machine Name" />
                        </Column>

                        <Column>
                            <Text text="Defect Name" />
                        </Column>

                        <Column>
                            <Text text="Meter Reading" />
                        </Column>

                        <Column>
                            <Text text="Process" />
                        </Column>

                        <Column>
                            <Text text="Time" />
                        </Column>

                        <Column hAlign="Center">
                            <Text text="Delete" />
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{vm>operator}" />

                                <Text text="{vm>machineName}" />

                                <ObjectIdentifier title="{vm>defectName}" />

                                <Text text="{vm>meterReading} m" />

                                <Text text="{vm>processName}" />

                                <Text text="{vm>timestamp}" />

                                <Button
                                    icon="sap-icon://delete"
                                    press=".onDeleteDefect"
                                />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>

            </VBox>
        </content>

        <footer>
            <OverflowToolbar>
                <ToolbarSpacer />

                <Button
                    text="Cancel"
                    type="Reject"
                    icon="sap-icon://decline"
                    press=".onCancel"
                />

                <Button
                    text="Submit Inspection Log"
                    type="Accept"
                    icon="sap-icon://accept"
                    press=".onFinalSubmit"
                />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>